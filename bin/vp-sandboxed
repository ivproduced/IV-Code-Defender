#!/usr/bin/env bash
# Copyright 2026 IVProduced contributors
# SPDX-License-Identifier: Apache-2.0
# Run vuln-pipeline with the agent sandbox active. Verifies runsc + the
# egress proxy are up, then sets the env the pipeline reads (sandbox.py) and
# execs through. Everything else — spawning the per-agent gVisor containers
# — happens inside the pipeline.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
NET=${VULN_PIPELINE_AGENT_NETWORK:-vp-internal}
PROXY_NAME=vp-egress-proxy
RUNTIME=${VULN_PIPELINE_AGENT_RUNTIME:-runsc}
ENGINE=${VULN_PIPELINE_CONTAINER_ENGINE:-docker}

# Preserve the fork's --provider / VULN_PIPELINE_PROVIDER interface while
# making upstream's environment-based egress preflight see the same choice.
provider=${VULN_PIPELINE_PROVIDER:-}
previous=
for arg in "$@"; do
    if [ "$previous" = "--provider" ]; then
        provider=$arg
        break
    fi
    case "$arg" in
        --provider=*) provider=${arg#--provider=} ;;
    esac
    previous=$arg
done
case "$provider" in
    bedrock)
        export CLAUDE_CODE_USE_BEDROCK=1
        unset CLAUDE_CODE_USE_VERTEX
        ;;
    vertex)
        export CLAUDE_CODE_USE_VERTEX=1
        unset CLAUDE_CODE_USE_BEDROCK
        ;;
    anthropic)
        unset CLAUDE_CODE_USE_BEDROCK CLAUDE_CODE_USE_VERTEX
        ;;
    "") ;;
esac

case "$ENGINE" in
    docker)
        docker info --format '{{range $k,$v := .Runtimes}}{{$k}} {{end}}' \
            | tr ' ' '\n' | grep -qx "$RUNTIME" \
            || { echo "error: runtime '$RUNTIME' not registered; run scripts/setup_sandbox.sh" >&2; exit 1; }
        ;;
    podman)
        [ "$(id -u)" -eq 0 ] \
            || { echo "error: Podman sandboxing requires rootful Podman; use sudo -E $0 ..." >&2; exit 1; }
        [ -z "${CONTAINER_HOST:-}${CONTAINER_CONNECTION:-}" ] \
            || { echo "error: Podman sandboxing requires the local service; unset CONTAINER_HOST and CONTAINER_CONNECTION" >&2; exit 1; }
        podman run --rm --runtime="$RUNTIME" alpine:3.21 true \
            || { echo "error: runtime '$RUNTIME' unavailable; run scripts/setup_podman_sandbox.sh" >&2; exit 1; }
        ;;
    *)  echo "error: VULN_PIPELINE_CONTAINER_ENGINE must be docker or podman" >&2; exit 1 ;;
esac

# docker inspect exits 0 even when the container isn't on $NET — the Go
# template just renders "<no value>". Guard against that and empty output
# explicitly, not just inspect's exit code.
proxy_ip=$("$ENGINE" inspect "$PROXY_NAME" --format \
    '{{(index .NetworkSettings.Networks "'"$NET"'").IPAddress}}' 2>/dev/null) || proxy_ip=""
if [ -z "$proxy_ip" ] || [ "$proxy_ip" = "<no value>" ]; then
    echo "error: ${PROXY_NAME} not running on ${NET}; run scripts/setup_sandbox.sh" >&2
    exit 1
fi

export VULN_PIPELINE_AGENT_RUNTIME="$RUNTIME"
export VULN_PIPELINE_AGENT_NETWORK="$NET"
export VULN_PIPELINE_EGRESS_PROXY="http://${proxy_ip}:3128"

PROXY_ALLOW=$("$ENGINE" inspect "$PROXY_NAME" --format \
    '{{range .Config.Env}}{{println .}}{{end}}' | sed -n 's/^VP_EGRESS_ALLOW=//p')
"$REPO_ROOT/.venv/bin/python3" -c \
    'import sys; from harness.auth import check_egress_satisfied; check_egress_satisfied(sys.argv[1])' \
    "$PROXY_ALLOW" \
    || { echo "  → re-run scripts/setup_sandbox.sh with current provider env set" >&2; exit 1; }

exec "$REPO_ROOT/.venv/bin/vuln-pipeline" "$@"
